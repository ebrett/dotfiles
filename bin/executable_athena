#!/usr/bin/env zsh
# Launch or attach to the Athena development tmux session

SESSION="athena"
ATHENA_DIR="$HOME/Projects/demsabroad/athena"
OBSIDIAN_ATHENA="$HOME/vaults/knowledge-base/01_Projects"

# Attach if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach-session -t "$SESSION"
fi

# Create session with first window: Rails dev server
tmux new-session -d -s "$SESSION" -n "dev" -c "$ATHENA_DIR"
tmux send-keys -t "$SESSION:dev" "bin/dev" Enter

# Window 2: general shell
tmux new-window -t "$SESSION" -n "shell" -c "$ATHENA_DIR"

# Window 3: PAI live mode
tmux new-window -t "$SESSION" -n "pai" -c "$ATHENA_DIR"
tmux send-keys -t "$SESSION:pai" "pai -l" Enter

# Window 4: Obsidian Athena notes (nvim)
tmux new-window -t "$SESSION" -n "obsidian" -c "$OBSIDIAN_ATHENA"
tmux send-keys -t "$SESSION:obsidian" "nvim athena.md" Enter

# Window 5: git
tmux new-window -t "$SESSION" -n "git" -c "$ATHENA_DIR"
tmux send-keys -t "$SESSION:git" "git status" Enter

# Focus the dev window on attach
tmux select-window -t "$SESSION:dev"

exec tmux attach-session -t "$SESSION"
